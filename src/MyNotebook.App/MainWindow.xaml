<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MyNotebook.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyNotebook.App"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <!-- Harmonize selection across the folder rail and the note list: drop the left
                 accent pill so both panes show the same clean, rounded, inset highlight. -->
            <SolidColorBrush x:Key="ListViewItemSelectionIndicatorBrush" Color="Transparent" />
            <SolidColorBrush x:Key="TreeViewItemSelectionIndicatorBrush" Color="Transparent" />
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar with centered search. The search box sits inside the drag
             region; a passthrough rectangle (set in code) keeps it interactive. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" SizeChanged="AppTitleBar_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="TitleLeft" Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="8,0,8,0" Spacing="2"
                        SizeChanged="TitleLeft_SizeChanged">
                <Button x:Name="RailToggleBtn" Click="ToggleRail_Click" Background="Transparent"
                        BorderThickness="0" Width="36" Height="32" Padding="0" CornerRadius="6"
                        ToolTipService.ToolTip="Hide / show folders">
                    <FontIcon Glyph="&#xE700;" FontSize="15" />
                </Button>
                <Button x:Name="ListToggleBtn" Click="ToggleList_Click" Background="Transparent"
                        BorderThickness="0" Width="36" Height="32" Padding="0" CornerRadius="6"
                        ToolTipService.ToolTip="Hide / show the note list">
                    <FontIcon Glyph="&#xE8A4;" FontSize="15" />
                </Button>
                <TextBlock Text="My Notebook" VerticalAlignment="Center" FontWeight="SemiBold"
                           Margin="8,0,8,0" />
            </StackPanel>
            <AutoSuggestBox x:Name="SearchBox" Grid.Column="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Width="440" Margin="12,0"
                            PlaceholderText="Search notes and screenshots…"
                            QueryIcon="Find"
                            SizeChanged="SearchBox_SizeChanged"
                            TextChanged="SearchBox_TextChanged"
                            QuerySubmitted="SearchBox_QuerySubmitted"
                            KeyDown="SearchBox_KeyDown"
                            SuggestionChosen="SearchBox_SuggestionChosen" />
        </Grid>

        <!-- Sidebar (tree) | splitter | detail -->
        <Grid x:Name="ContentArea" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="RailColumn" Width="194" MinWidth="150" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition x:Name="NoteListColumn" Width="300" MinWidth="230" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: action header (aligned with the editor toolbar), tree, settings.
                 Background is set in code: a layer brush by default, or a theme tint. -->
            <!-- Folder rail: folders + All Notes / Smart Folders / Trash, then Timeline + Settings -->
            <Border x:Name="RailCard" Grid.Column="0" CornerRadius="8,0,0,8" Margin="8,8,0,8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid x:Name="SidebarRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="6,0,6,0" BorderThickness="0,0,0,1"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid VerticalAlignment="Center">
                        <Button x:Name="NotebookSwitcher" Click="NotebookSwitcher_Click"
                                HorizontalAlignment="Left" Background="Transparent" BorderThickness="0"
                                Padding="6,4" CornerRadius="6" MaxWidth="150"
                                ToolTipService.ToolTip="Switch notebook">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon x:Name="NotebookIcon" Glyph="&#xE82D;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="NotebookName" Text="My Notebook" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <FontIcon Glyph="&#xE70D;" FontSize="10" VerticalAlignment="Center"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NewFolderButton" Click="NewFolder_Click" HorizontalAlignment="Right"
                                Background="Transparent" BorderThickness="0" Width="32" Height="32"
                                Padding="0" CornerRadius="6" ToolTipService.ToolTip="New folder">
                            <FontIcon Glyph="&#xE8F4;" FontSize="15" />
                        </Button>
                    </Grid>
                </Border>

                <TreeView x:Name="SidebarTree" Grid.Row="1" Margin="0,4,0,0"
                          AutomationProperties.AutomationId="SidebarTree"
                          SelectionMode="Single"
                          ItemInvoked="SidebarTree_ItemInvoked"
                          Expanding="SidebarTree_Expanding"
                          KeyDown="SidebarTree_KeyDown"
                          RightTapped="SidebarTree_RightTapped"
                          AllowDrop="True" DragOver="Rail_DragOver" Drop="Rail_Drop">
                    <TreeView.Resources>
                        <!-- Match the note-list rows: rounded, inset selection instead of a full-width bar. -->
                        <Style TargetType="TreeViewItem">
                            <Setter Property="CornerRadius" Value="6" />
                            <Setter Property="Margin" Value="5,1" />
                            <Setter Property="MinHeight" Value="32" />
                        </Style>
                    </TreeView.Resources>
                    <TreeView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="{Binding Content.IconGlyph}" FontSize="15"
                                          VerticalAlignment="Center"
                                          Foreground="{Binding Content.IconBrush}" />
                                <TextBlock Text="{Binding Content.DisplayTitle}"
                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>

                <StackPanel Grid.Row="2" Margin="6,4,6,6">
                    <Button x:Name="TimelineButton" Click="Timeline_Click" HorizontalAlignment="Stretch"
                            Padding="8" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <FontIcon Glyph="&#xE81C;" FontSize="16" />
                            <TextBlock Text="Timeline" />
                        </StackPanel>
                    </Button>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="SettingsButton" Grid.Column="0" Click="SettingsButton_Click"
                                HorizontalAlignment="Stretch" Padding="8" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE713;" FontSize="16" />
                                <TextBlock Text="Settings" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="AboutFooterButton" Grid.Column="1" Click="AboutFooter_Click"
                                Background="Transparent" BorderThickness="0" Width="36" Height="36"
                                Padding="0" CornerRadius="6" ToolTipService.ToolTip="About My Notebook">
                            <FontIcon Glyph="&#xE946;" FontSize="16" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Grid>
            </Border>

            <!-- Note list (sits flush against the rail; the rail's shadow falls on its left edge) -->
            <Border x:Name="NoteListCard" Grid.Column="2" CornerRadius="0,8,8,0" Margin="0,8,2,8"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Grid x:Name="NoteListRoot">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Padding="12,0,6,0" BorderThickness="0,0,0,1"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock x:Name="NoteListTitle" Text="All Notes" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="NoteListCount" FontSize="11" Opacity="0.55" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="1">
                            <Button x:Name="SortButton" Background="Transparent" BorderThickness="0"
                                    Width="34" Height="32" Padding="0" CornerRadius="6" ToolTipService.ToolTip="Sort">
                                <FontIcon Glyph="&#xE8CB;" FontSize="15" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Recently edited" Tag="modified" Click="Sort_Click" />
                                        <MenuFlyoutItem Text="Recently created" Tag="created" Click="Sort_Click" />
                                        <MenuFlyoutItem Text="Title (A–Z)" Tag="title" Click="Sort_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button x:Name="SelectButton" Click="ToggleSelectMode_Click" Background="Transparent"
                                    BorderThickness="0" Width="34" Height="32" Padding="0" CornerRadius="6"
                                    ToolTipService.ToolTip="Select multiple">
                                <FontIcon Glyph="&#xE762;" FontSize="15" />
                            </Button>
                            <Button x:Name="NewThreadButton" Click="NewThread_Click" Background="Transparent"
                                    BorderThickness="0" Width="34" Height="32" Padding="0" CornerRadius="6"
                                    ToolTipService.ToolTip="New screenshot thread (Ctrl+T)">
                                <FontIcon Glyph="&#xE722;" FontSize="15" />
                            </Button>
                            <Button x:Name="NewNoteButton" Click="NewNote_Click" Style="{StaticResource AccentButtonStyle}"
                                    Width="34" Height="32" Padding="0" CornerRadius="6" Margin="2,0,0,0"
                                    ToolTipService.ToolTip="New note (Ctrl+N)">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <ListView x:Name="NoteList" Grid.Row="1" SelectionMode="Extended" IsItemClickEnabled="False"
                          SelectionChanged="NoteList_SelectionChanged"
                          CanDragItems="True" DragItemsStarting="NoteList_DragItemsStarting"
                          RightTapped="NoteList_RightTapped" KeyDown="NoteList_KeyDown">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="10,7" />
                            <Setter Property="Margin" Value="5,1" />
                            <Setter Property="CornerRadius" Value="6" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:NoteListRow">
                            <Grid ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="{x:Bind Glyph}" FontSize="15"
                                          VerticalAlignment="Top" Margin="0,2,0,0"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <StackPanel Grid.Column="1" Spacing="1">
                                    <TextBlock Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{x:Bind Subtitle, Mode=OneWay}" FontSize="12" Opacity="0.6"
                                               MaxLines="1" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                                <FontIcon Grid.Column="2" Glyph="&#xE840;" FontSize="12" VerticalAlignment="Top"
                                          Margin="0,3,0,0" Visibility="{x:Bind PinVisibility, Mode=OneWay}"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <TextBlock x:Name="NoteListEmpty" Grid.Row="1" Text="No notes here yet." Opacity="0.5"
                           HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed" />

                <Border x:Name="SelectBar" Grid.Row="2" Visibility="Collapsed" Padding="8"
                        BorderThickness="0,1,0,0" BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SelectCount" Grid.Column="0" Text="0 selected"
                                   VerticalAlignment="Center" FontSize="13" />
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                            <Button x:Name="BulkMoveButton" ToolTipService.ToolTip="Move to…">
                                <FontIcon Glyph="&#xE8DE;" FontSize="14" />
                                <Button.Flyout>
                                    <MenuFlyout x:Name="BulkMoveFlyout" />
                                </Button.Flyout>
                            </Button>
                            <Button x:Name="BulkPinButton" Click="BulkPin_Click" ToolTipService.ToolTip="Pin / Unpin">
                                <FontIcon Glyph="&#xE718;" FontSize="14" />
                            </Button>
                            <Button x:Name="BulkDeleteButton" Click="BulkDelete_Click" ToolTipService.ToolTip="Delete">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" />
                            </Button>
                            <Button Content="Done" Click="CloseSelect_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
            </Border>

            <!-- The rail's "shadow" cast onto the note list: a soft gradient on the list's left edge. -->
            <Rectangle x:Name="RailShadowEdge" Grid.Column="2" Width="14" HorizontalAlignment="Left"
                       Margin="0,8,0,8" IsHitTestVisible="False">
                <Rectangle.Fill>
                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                        <GradientStop Offset="0" Color="#33000000" />
                        <GradientStop Offset="1" Color="#00000000" />
                    </LinearGradientBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Rail resize grip: a thin overlay on the note list's left edge (the rail/list seam).
                 Declared after the list so it stays on top and grabbable. -->
            <local:ColumnSizer x:Name="RailSplitter" Grid.Column="2" Width="8" HorizontalAlignment="Left"
                               Margin="0,8,0,8" Background="Transparent"
                               PointerPressed="RailSplitter_PointerPressed"
                               PointerMoved="RailSplitter_PointerMoved"
                               PointerReleased="RailSplitter_PointerReleased" />

            <!-- Draggable column splitter. Background set in code so it matches the themed
                 chrome instead of letting the Mica backdrop (wallpaper) show through. -->
            <local:ColumnSizer x:Name="SidebarSplitter" Grid.Column="3" Width="6"
                               Background="Transparent"
                               PointerPressed="Splitter_PointerPressed"
                               PointerMoved="Splitter_PointerMoved"
                               PointerReleased="Splitter_PointerReleased" />

            <!-- Detail: editor (note) OR thread (screenshots) OR settings.
                 No outer padding so the editor toolbar can dock flush at the top,
                 aligned with the sidebar's action header. Panes add their own padding.
                 Background (the "desk" the page floats on) is set in code per theme. -->
            <Grid x:Name="ContentRoot" Grid.Column="4">
                <!-- OneNote-style page: compact toolbar above a "paper" surface that holds
                     the title block (light typeface, date + time, rule line) and a
                     borderless editor sitting directly on the paper. -->
                <Grid x:Name="EditorPane" Visibility="Collapsed">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.ThemeDictionaries>
                                <ResourceDictionary x:Key="Light">
                                    <SolidColorBrush x:Key="PaperBrush" Color="#FFFFFF" />
                                    <SolidColorBrush x:Key="PaperStrokeBrush" Color="#E3E3E3" />
                                    <SolidColorBrush x:Key="PaperRuleBrush" Color="#D5D5D5" />
                                </ResourceDictionary>
                                <ResourceDictionary x:Key="Dark">
                                    <SolidColorBrush x:Key="PaperBrush" Color="#272727" />
                                    <SolidColorBrush x:Key="PaperStrokeBrush" Color="#3F3F3F" />
                                    <SolidColorBrush x:Key="PaperRuleBrush" Color="#4A4A4A" />
                                </ResourceDictionary>
                                <ResourceDictionary x:Key="HighContrast">
                                    <SolidColorBrush x:Key="PaperBrush" Color="{ThemeResource SystemColorWindowColor}" />
                                    <SolidColorBrush x:Key="PaperStrokeBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                                    <SolidColorBrush x:Key="PaperRuleBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                                </ResourceDictionary>
                            </ResourceDictionary.ThemeDictionaries>

                            <!-- Borderless text controls on the paper (lightweight styling). -->
                            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />

                            <Style x:Key="FmtButton" TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Width" Value="34" />
                                <Setter Property="Height" Value="32" />
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                            <Style x:Key="FmtSeparator" TargetType="Rectangle">
                                <Setter Property="Width" Value="1" />
                                <Setter Property="Height" Value="18" />
                                <Setter Property="Margin" Value="5,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Fill" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            </Style>
                        </ResourceDictionary>
                    </Grid.Resources>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Find &amp; replace (Ctrl+F) -->
                    <Border x:Name="FindBar" Grid.Row="0" Visibility="Collapsed" Margin="16,12,16,0"
                            CornerRadius="6" BorderThickness="1" Padding="6" HorizontalAlignment="Left"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox x:Name="FindBox" Width="150" PlaceholderText="Find"
                                     KeyDown="FindBox_KeyDown" TextChanged="FindBox_TextChanged" />
                            <TextBlock x:Name="FindCount" VerticalAlignment="Center" MinWidth="52"
                                       FontSize="12" Opacity="0.7" Text="" />
                            <Button Content="&#x2039;" Click="FindPrev_Click" ToolTipService.ToolTip="Previous (Shift+Enter)" />
                            <Button Content="&#x203A;" Click="FindNext_Click" ToolTipService.ToolTip="Next (Enter)" />
                            <ToggleButton x:Name="FindCase" Click="FindCase_Click" ToolTipService.ToolTip="Match case">
                                <TextBlock Text="Aa" FontSize="13" />
                            </ToggleButton>
                            <Rectangle Width="1" Margin="2,3" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            <TextBox x:Name="ReplaceBox" Width="150" PlaceholderText="Replace with" />
                            <Button Content="Replace" Click="Replace_Click" />
                            <Button Content="All" Click="ReplaceAll_Click" ToolTipService.ToolTip="Replace all" />
                            <Button Content="&#x2715;" Click="CloseFind_Click" ToolTipService.ToolTip="Close (Esc)" />
                        </StackPanel>
                    </Border>

                    <!-- Formatting toolbar — docked flush to the page, aligned with the
                         sidebar action header. Drives the WebView2 editor via execCommand. -->
                    <Border x:Name="ToolbarBar" Grid.Row="1" Padding="10,6"
                            Margin="2,8,8,0" CornerRadius="8,8,0,0" BorderThickness="0,0,0,1"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                      <StackPanel Orientation="Vertical" Spacing="4">
                        <!-- Row 1: text formatting -->
                        <StackPanel Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                            <!-- Undo / redo -->
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Undo (Ctrl+Z)" Click="Undo_Click">
                                <FontIcon Glyph="&#xE7A7;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Redo (Ctrl+Y)" Click="Redo_Click">
                                <FontIcon Glyph="&#xE7A6;" FontSize="15" />
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <!-- Paragraph -->
                            <Button Width="Auto" Height="32" Padding="8,0" CornerRadius="6"
                                    Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Paragraph styles">
                                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                    <TextBlock Text="Styles" FontSize="14" VerticalAlignment="Center" />
                                    <FontIcon Glyph="&#xE70D;" FontSize="10" />
                                </StackPanel>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Title" Click="StyleTitle_Click" />
                                        <MenuFlyoutItem Text="Heading" Click="StyleHeading_Click" />
                                        <MenuFlyoutItem Text="Body" Click="StyleBody_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Smaller text" Click="FontSmaller_Click">
                                <TextBlock Text="A&#x2212;" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Bigger text" Click="FontBigger_Click">
                                <TextBlock Text="A+" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" Width="44" ToolTipService.ToolTip="Font">
                                <TextBlock Text="Aa" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Calibri" Tag="Calibri" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Segoe UI" Tag="Segoe UI" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Times New Roman" Tag="Times New Roman" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Georgia" Tag="Georgia" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Consolas" Tag="Consolas" Click="Font_Click" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Padauk (Myanmar)" Tag="Padauk" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Myanmar Text" Tag="Myanmar Text" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Noto Sans Myanmar" Tag="Noto Sans Myanmar" Click="Font_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <!-- Character emphasis + color -->
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Bold (Ctrl+B)" Click="Bold_Click">
                                <FontIcon Glyph="&#xE8DD;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Italic (Ctrl+I)" Click="Italic_Click">
                                <FontIcon Glyph="&#xE8DB;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Underline (Ctrl+U)" Click="Underline_Click">
                                <FontIcon Glyph="&#xE8DC;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Strikethrough" Click="Strike_Click">
                                <FontIcon Glyph="&#xEDE0;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Superscript" Click="Super_Click">
                                <TextBlock Text="x&#x00B2;" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Subscript" Click="Sub_Click">
                                <TextBlock Text="x&#x2082;" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Text color">
                                <FontIcon Glyph="&#xE8D3;" FontSize="15" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Default" Click="ColorDefault_Click" />
                                        <MenuFlyoutItem Text="Red" Click="ColorRed_Click" />
                                        <MenuFlyoutItem Text="Green" Click="ColorGreen_Click" />
                                        <MenuFlyoutItem Text="Blue" Click="ColorBlue_Click" />
                                        <MenuFlyoutItem Text="Orange" Click="ColorOrange_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Highlight">
                                <FontIcon Glyph="&#xE891;" FontSize="15" />
                                <Button.Flyout>
                                    <Flyout x:Name="HighlightFlyout">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Button Width="28" Height="28" CornerRadius="6" Padding="0" BorderThickness="1"
                                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                    Background="#FFF2A8" Tag="#fff2a8" Click="Highlight_Click" ToolTipService.ToolTip="Yellow" />
                                            <Button Width="28" Height="28" CornerRadius="6" Padding="0" BorderThickness="1"
                                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                    Background="#D6F84A" Tag="#d6f84a" Click="Highlight_Click" ToolTipService.ToolTip="Lime" />
                                            <Button Width="28" Height="28" CornerRadius="6" Padding="0" BorderThickness="1"
                                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                    Background="#B6F0BD" Tag="#b6f0bd" Click="Highlight_Click" ToolTipService.ToolTip="Green" />
                                            <Button Width="28" Height="28" CornerRadius="6" Padding="0" BorderThickness="1"
                                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                    Background="#FFC7DD" Tag="#ffc7dd" Click="Highlight_Click" ToolTipService.ToolTip="Pink" />
                                            <Button Width="28" Height="28" CornerRadius="6" Padding="0" BorderThickness="1"
                                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                    Background="#BFE0FF" Tag="#bfe0ff" Click="Highlight_Click" ToolTipService.ToolTip="Blue" />
                                            <Button Width="28" Height="28" CornerRadius="6" Padding="0" BorderThickness="1"
                                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                    Background="#FFD8A8" Tag="#ffd8a8" Click="Highlight_Click" ToolTipService.ToolTip="Orange" />
                                            <Button Width="28" Height="28" CornerRadius="6" Padding="0" BorderThickness="1"
                                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                                    Background="#E3CCFF" Tag="#e3ccff" Click="Highlight_Click" ToolTipService.ToolTip="Purple" />
                                            <Button Width="28" Height="28" CornerRadius="6" Padding="0" Tag="transparent"
                                                    Click="Highlight_Click" ToolTipService.ToolTip="No highlight">
                                                <FontIcon Glyph="&#xE894;" FontSize="12" />
                                            </Button>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Clear formatting" Click="ClearFormat_Click">
                                <TextBlock Text="T&#x2715;" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <!-- Note tools -->
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Linked references (backlinks)" Click="LinksButton_Click">
                                <FontIcon Glyph="&#xE8A5;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Focus mode (F11)" Click="FocusMode_Click">
                                <FontIcon Glyph="&#xE740;" FontSize="15" />
                            </Button>
                            <Button x:Name="ReadAloudButton" Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Read aloud" Click="ReadAloud_Click">
                                <FontIcon x:Name="ReadAloudIcon" Glyph="&#xE767;" FontSize="15" />
                            </Button>
                            <Button x:Name="RecordButton" Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Record audio" Click="RecordAudio_Click">
                                <FontIcon x:Name="RecordIcon" Glyph="&#xE720;" FontSize="15" />
                            </Button>
                        </StackPanel>
                        <!-- Row 2: paragraph, structure & insert -->
                        <StackPanel Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                            <!-- Alignment -->
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Align left (Ctrl+L)" Click="AlignLeft_Click">
                                <FontIcon Glyph="&#xE8E4;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Align center (Ctrl+E)" Click="AlignCenter_Click">
                                <FontIcon Glyph="&#xE8E3;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Align right (Ctrl+R)" Click="AlignRight_Click">
                                <FontIcon Glyph="&#xE8E2;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Justify (Ctrl+J)" Click="AlignJustify_Click">
                                <StackPanel Width="15" Spacing="2.5" VerticalAlignment="Center">
                                    <Rectangle Height="1.6" RadiusX="1" RadiusY="1" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <Rectangle Height="1.6" RadiusX="1" RadiusY="1" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <Rectangle Height="1.6" RadiusX="1" RadiusY="1" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                    <Rectangle Height="1.6" RadiusX="1" RadiusY="1" Fill="{ThemeResource TextFillColorPrimaryBrush}" />
                                </StackPanel>
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <!-- Indent -->
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Increase indent (Ctrl+M)" Click="Indent_Click">
                                <TextBlock Text="&#x21E5;" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Decrease indent (Ctrl+Shift+M)" Click="Outdent_Click">
                                <TextBlock Text="&#x21E4;" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <!-- Lists -->
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Bullet list" Click="Bullets_Click">
                                <FontIcon Glyph="&#xE8FD;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Numbered list" Click="Numbered_Click">
                                <TextBlock Text="1." FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Checklist" Click="Checklist_Click">
                                <FontIcon Glyph="&#xE73A;" FontSize="15" />
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <!-- Blocks: quote, code, divider -->
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Quote" Click="Quote_Click">
                                <TextBlock Text="&#x275D;" FontSize="17" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Code block" Click="Code_Click">
                                <TextBlock Text="&lt;/&gt;" FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Divider" Click="Divider_Click">
                                <TextBlock Text="&#x2015;" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <!-- Insert: link, table -->
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Insert or edit link">
                                <FontIcon Glyph="&#xE71B;" FontSize="15" />
                                <Button.Flyout>
                                    <Flyout x:Name="LinkFlyout">
                                        <StackPanel Spacing="8" Width="264">
                                            <TextBlock Text="Link address" FontSize="12" Opacity="0.7" />
                                            <TextBox x:Name="LinkUrlBox" PlaceholderText="https://…" />
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Button Content="Apply" Style="{StaticResource AccentButtonStyle}" Click="LinkApply_Click" />
                                                <Button Content="Remove link" Click="LinkRemove_Click" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Flyout>
                                </Button.Flyout>
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Insert table">
                                <TextBlock Text="&#x25A6;" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Table 2 &#xD7; 2" Tag="2x2" Click="Table_Click" />
                                        <MenuFlyoutItem Text="Table 3 &#xD7; 3" Tag="3x3" Click="Table_Click" />
                                        <MenuFlyoutItem Text="Table 4 &#xD7; 3" Tag="3x4" Click="Table_Click" />
                                        <MenuFlyoutItem Text="Table 2 rows &#xD7; 4 cols" Tag="2x4" Click="Table_Click" />
                                        <MenuFlyoutItem Text="Table 5 rows &#xD7; 2 cols" Tag="5x2" Click="Table_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Insert equation (math)" Click="InsertEquation_Click">
                                <TextBlock Text="fx" FontFamily="Georgia" FontStyle="Italic" FontSize="15"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Insert picture from a file" Click="InsertImageFile_Click">
                                <FontIcon Glyph="&#xE91B;" FontSize="15" />
                            </Button>
                        </StackPanel>
                      </StackPanel>
                    </Border>

                    <!-- The page: the rounded-bottom body of the editor card, flush under the toolbar. -->
                    <Border x:Name="PaperBorder" Grid.Row="2" CornerRadius="0,0,8,8" BorderThickness="0"
                            Margin="2,0,8,8"
                            Background="{ThemeResource PaperBrush}"
                            BorderBrush="{ThemeResource PaperStrokeBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- OneNote title block (wider side margins) -->
                            <StackPanel Grid.Row="0" Padding="72,28,72,0">
                                <TextBox x:Name="TitleBox" PlaceholderText="Page title"
                                         FontSize="30" FontWeight="Light" FontFamily="Calibri Light"
                                         Padding="0" Margin="0"
                                         TextChanged="TitleBox_TextChanged" />
                                <Grid Margin="1,8,0,0">
                                    <TextBlock x:Name="DateLine" FontSize="12" Opacity="0.55" />
                                    <TextBlock x:Name="SaveStatus" FontSize="12" Opacity="0" HorizontalAlignment="Right"
                                               VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="" />
                                </Grid>
                                <TextBlock x:Name="EditedLine" FontSize="12" Opacity="0.55" Margin="1,1,0,0" />
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <ItemsControl x:Name="NoteTagsList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <Button Padding="8,2" Background="Transparent">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8EC;" FontSize="12" />
                                            <TextBlock Text="Tag" FontSize="12" />
                                        </StackPanel>
                                        <Button.Flyout>
                                            <Flyout>
                                                <StackPanel Width="220" Spacing="8">
                                                    <TextBlock Text="Add a tag" FontWeight="SemiBold" />
                                                    <AutoSuggestBox x:Name="AddTagBox" PlaceholderText="tag name"
                                                                    QueryIcon="Add"
                                                                    TextChanged="AddTagBox_TextChanged"
                                                                    QuerySubmitted="AddTagBox_QuerySubmitted" />
                                                    <Button Content="Add tag" Click="AddTag_Click" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                                <Rectangle Height="1" Fill="{ThemeResource PaperRuleBrush}"
                                           HorizontalAlignment="Stretch" Margin="0,14,0,0" />
                            </StackPanel>

                            <!-- Body: a stack of plain-text + image blocks (true inline images).
                                 The hidden RichEditBox stays only so the legacy formatting code
                                 still compiles; the block editor below is what's used. -->
                            <Grid Grid.Row="1">
                                <Canvas x:Name="PaperCanvas" IsHitTestVisible="False"
                                        SizeChanged="PaperCanvas_SizeChanged" />
                                <RichEditBox x:Name="Editor" Visibility="Collapsed" FontFamily="Calibri"
                                             Background="Transparent" PlaceholderText="Start typing…"
                                             Padding="72,14,72,40"
                                             TextChanged="Editor_TextChanged" Tapped="Editor_Tapped"
                                             Paste="Editor_Paste" DoubleTapped="Editor_DoubleTapped" />
                                <!-- The real editor: a contenteditable HTML document. This is the
                                     only host that gives one continuous document with full-res,
                                     clickable, truly-inline images. -->
                                <WebView2 x:Name="NoteWeb" DefaultBackgroundColor="Transparent" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Screenshot thread: vertical image cards with timestamp -->
                <Grid x:Name="ThreadPane" Visibility="Collapsed" Padding="16" IsTabStop="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ThreadTitleBox" Grid.Column="0" FontSize="20" FontWeight="SemiBold"
                                 BorderThickness="0" PlaceholderText="Thread title"
                                 TextChanged="TitleBox_TextChanged" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="ThreadExportAll_Click" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Export every image in this thread to a folder">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE896;" FontSize="14" />
                                <TextBlock Text="Export all" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ListView x:Name="ThreadCards" Grid.Row="1" SelectionMode="None"
                              Background="Transparent" Padding="0"
                              CanReorderItems="True" AllowDrop="True" CanDragItems="True"
                              DragItemsCompleted="ThreadCards_DragItemsCompleted">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="44" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Timeline rail: line above + numbered node + line below (joins into one continuous rail) -->
                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Rectangle Grid.Row="0" Width="2" Height="14" VerticalAlignment="Top"
                                                   HorizontalAlignment="Center" Visibility="{Binding TopLineVisibility}"
                                                   Fill="{ThemeResource AccentFillColorTertiaryBrush}" />
                                        <Border Grid.Row="0" Width="26" Height="26" CornerRadius="13" Margin="0,14,0,0"
                                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                                            <TextBlock Text="{Binding NumberText}" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Rectangle Grid.Row="1" Width="2" HorizontalAlignment="Center"
                                                   VerticalAlignment="Stretch" Visibility="{Binding BottomLineVisibility}"
                                                   Fill="{ThemeResource AccentFillColorTertiaryBrush}" />
                                    </Grid>

                                    <Border Grid.Column="1" Margin="0,0,0,12" CornerRadius="8" Padding="8"
                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                            BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Timestamp}" Opacity="0.6" FontSize="12" />
                                            <FontIcon Grid.Column="1" Glyph="&#xE76F;" FontSize="12" Opacity="0.4"
                                                      ToolTipService.ToolTip="Drag the card to reorder" />
                                        </Grid>
                                        <Image Source="{Binding Bitmap}" Stretch="Uniform"
                                               MaxHeight="480" HorizontalAlignment="Left"
                                               Tapped="ThreadImage_Tapped"
                                               ToolTipService.ToolTip="Click to view at 100%">
                                            <Image.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="View at 100%" Click="ThreadImageView_Click" />
                                                    <MenuFlyoutItem Text="Copy image" Click="ThreadImageCopy_Click" />
                                                    <MenuFlyoutItem Text="Export image…" Click="ThreadImageExport_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Delete image" Click="ThreadImageDelete_Click" />
                                                </MenuFlyout>
                                            </Image.ContextFlyout>
                                        </Image>
                                        <TextBlock Text="{Binding Caption}" Opacity="0.8"
                                                   Margin="0,6,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <InfoBar x:Name="PasteHint" Grid.Row="2" IsOpen="True" IsClosable="False"
                             Severity="Informational" Margin="0,8,0,0"
                             Message="Press Ctrl+V to paste a screenshot into this thread." />
                </Grid>

                <!-- Search results -->
                <Grid x:Name="SearchResultsPane" Visibility="Collapsed" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SearchResultsHeader" Grid.Row="0" FontSize="13" Opacity="0.6" Margin="2,0,0,8" />
                    <ListView x:Name="SearchResultsList" Grid.Row="1" SelectionMode="Single"
                              IsItemClickEnabled="True" ItemClick="SearchResult_Click"
                              KeyDown="SearchResultsList_KeyDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="10,2" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>

                <!-- Timeline: every note grouped by date, with SemanticZoom to jump periods -->
                <Grid x:Name="TimelinePane" Visibility="Collapsed" Padding="16,12,16,0">
                    <Grid.Resources>
                        <CollectionViewSource x:Name="TimelineCvs" IsSourceGrouped="True" />
                    </Grid.Resources>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="2,0,2,8">
                        <TextBlock Text="Timeline" FontSize="20" FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="TimelineAxisCombo" HorizontalAlignment="Right" MinWidth="150"
                                  SelectionChanged="TimelineAxis_Changed">
                            <ComboBoxItem Content="Recently edited" Tag="Modified" IsSelected="True" />
                            <ComboBoxItem Content="Date created" Tag="Created" />
                        </ComboBox>
                    </Grid>

                    <SemanticZoom Grid.Row="1">
                        <SemanticZoom.ZoomedInView>
                            <ListView x:Name="TimelineList" SelectionMode="Single"
                                      IsItemClickEnabled="True" ItemClick="TimelineItem_Click">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="10,6" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.GroupStyle>
                                    <GroupStyle HidesIfEmpty="True">
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate x:DataType="local:TimelineGroup">
                                                <Border Padding="2,12,0,4">
                                                    <TextBlock Text="{x:Bind Key}" FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                                </Border>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ListView.GroupStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="local:TimelineRow">
                                        <Grid ColumnSpacing="10" Padding="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Glyph}" FontSize="15"
                                                       VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Spacing="1">
                                                <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"
                                                           FontSize="15" TextTrimming="CharacterEllipsis" />
                                                <TextBlock Text="{x:Bind Preview}" FontSize="12" Opacity="0.6"
                                                           MaxLines="1" TextTrimming="CharacterEllipsis"
                                                           Visibility="{x:Bind PreviewVisibility}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{x:Bind TimeText}" FontSize="12"
                                                       Opacity="0.55" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </SemanticZoom.ZoomedInView>
                        <SemanticZoom.ZoomedOutView>
                            <ListView x:Name="TimelineJumpList" SelectionMode="Single">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="4" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Group.Key}" FontSize="16"
                                                   FontWeight="SemiBold" Padding="10,10" />
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </SemanticZoom.ZoomedOutView>
                    </SemanticZoom>
                </Grid>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyState" Text="Select or create a note."
                           Opacity="0.6" HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <!-- Floating exit affordance, shown only in focus mode -->
                <Button x:Name="FocusExitButton" Visibility="Collapsed" Click="FocusMode_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,18,0"
                        CornerRadius="6" ToolTipService.ToolTip="Exit focus mode (Esc)"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE73F;" FontSize="13" />
                        <TextBlock Text="Exit focus" FontSize="13" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
