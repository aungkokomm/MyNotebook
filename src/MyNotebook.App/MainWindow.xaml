<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MyNotebook.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MyNotebook.App"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom title bar with centered search. The search box sits inside the drag
             region; a passthrough rectangle (set in code) keeps it interactive. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" SizeChanged="AppTitleBar_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="My Notebook" VerticalAlignment="Center"
                       FontWeight="SemiBold" Margin="16,0,16,0" />
            <AutoSuggestBox x:Name="SearchBox" Grid.Column="1"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Width="440" Margin="12,0"
                            PlaceholderText="Search notes and screenshots…"
                            QueryIcon="Find"
                            SizeChanged="SearchBox_SizeChanged"
                            TextChanged="SearchBox_TextChanged"
                            QuerySubmitted="SearchBox_QuerySubmitted"
                            KeyDown="SearchBox_KeyDown"
                            SuggestionChosen="SearchBox_SuggestionChosen" />
        </Grid>

        <!-- Sidebar (tree) | splitter | detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarColumn" Width="260" MinWidth="180" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="320" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar: action header (aligned with the editor toolbar), tree, settings.
                 Background is set in code: a layer brush by default, or a theme tint. -->
            <Grid x:Name="SidebarRoot" Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="48" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Action header band -->
                <Border Grid.Row="0" Padding="8,0" BorderThickness="0,0,0,1"
                        BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="2" VerticalAlignment="Center">
                        <Button x:Name="NewNoteButton" Click="NewNote_Click"
                                Style="{StaticResource AccentButtonStyle}" Padding="10,6"
                                CornerRadius="6" ToolTipService.ToolTip="New note (Ctrl+N)">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="New note" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="NewThreadButton" Click="NewThread_Click"
                                Background="Transparent" BorderThickness="0" Width="34" Height="32"
                                Padding="0" CornerRadius="6"
                                ToolTipService.ToolTip="New screenshot thread (Ctrl+T)">
                            <FontIcon Glyph="&#xE722;" FontSize="15" />
                        </Button>
                        <Button x:Name="NewFolderButton" Click="NewFolder_Click"
                                Background="Transparent" BorderThickness="0" Width="34" Height="32"
                                Padding="0" CornerRadius="6"
                                ToolTipService.ToolTip="New folder">
                            <FontIcon Glyph="&#xE8F4;" FontSize="15" />
                        </Button>
                    </StackPanel>
                </Border>

                <TreeView x:Name="SidebarTree" Grid.Row="1" Margin="0,4,0,0"
                          AutomationProperties.AutomationId="SidebarTree"
                          SelectionMode="Single"
                          CanDragItems="True" CanReorderItems="True"
                          ItemInvoked="SidebarTree_ItemInvoked"
                          Expanding="SidebarTree_Expanding"
                          KeyDown="SidebarTree_KeyDown"
                          RightTapped="SidebarTree_RightTapped"
                          DragItemsStarting="SidebarTree_DragItemsStarting"
                          DragItemsCompleted="SidebarTree_DragItemsCompleted">
                    <TreeView.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Content.DisplayText}"
                                       TextTrimming="CharacterEllipsis" />
                        </DataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
                <Button Grid.Row="2" x:Name="SettingsButton" Click="SettingsButton_Click"
                        HorizontalAlignment="Stretch" Margin="8" Padding="8"
                        HorizontalContentAlignment="Left" Background="Transparent"
                        BorderThickness="0">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <FontIcon Glyph="&#xE713;" FontSize="16" />
                        <TextBlock Text="Settings" />
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Draggable column splitter. Background set in code so it matches the themed
                 chrome instead of letting the Mica backdrop (wallpaper) show through. -->
            <local:ColumnSizer x:Name="SidebarSplitter" Grid.Column="1" Width="6"
                               Background="Transparent"
                               PointerPressed="Splitter_PointerPressed"
                               PointerMoved="Splitter_PointerMoved"
                               PointerReleased="Splitter_PointerReleased" />

            <!-- Detail: editor (note) OR thread (screenshots) OR settings.
                 No outer padding so the editor toolbar can dock flush at the top,
                 aligned with the sidebar's action header. Panes add their own padding.
                 Background (the "desk" the page floats on) is set in code per theme. -->
            <Grid x:Name="ContentRoot" Grid.Column="2">
                <!-- OneNote-style page: compact toolbar above a "paper" surface that holds
                     the title block (light typeface, date + time, rule line) and a
                     borderless editor sitting directly on the paper. -->
                <Grid x:Name="EditorPane" Visibility="Collapsed">
                    <Grid.Resources>
                        <ResourceDictionary>
                            <ResourceDictionary.ThemeDictionaries>
                                <ResourceDictionary x:Key="Light">
                                    <SolidColorBrush x:Key="PaperBrush" Color="#FFFFFF" />
                                    <SolidColorBrush x:Key="PaperStrokeBrush" Color="#E3E3E3" />
                                    <SolidColorBrush x:Key="PaperRuleBrush" Color="#D5D5D5" />
                                </ResourceDictionary>
                                <ResourceDictionary x:Key="Dark">
                                    <SolidColorBrush x:Key="PaperBrush" Color="#272727" />
                                    <SolidColorBrush x:Key="PaperStrokeBrush" Color="#3F3F3F" />
                                    <SolidColorBrush x:Key="PaperRuleBrush" Color="#4A4A4A" />
                                </ResourceDictionary>
                                <ResourceDictionary x:Key="HighContrast">
                                    <SolidColorBrush x:Key="PaperBrush" Color="{ThemeResource SystemColorWindowColor}" />
                                    <SolidColorBrush x:Key="PaperStrokeBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                                    <SolidColorBrush x:Key="PaperRuleBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
                                </ResourceDictionary>
                            </ResourceDictionary.ThemeDictionaries>

                            <!-- Borderless text controls on the paper (lightweight styling). -->
                            <SolidColorBrush x:Key="TextControlBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="Transparent" />
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />

                            <Style x:Key="FmtButton" TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Width" Value="34" />
                                <Setter Property="Height" Value="32" />
                                <Setter Property="CornerRadius" Value="4" />
                            </Style>
                            <Style x:Key="FmtSeparator" TargetType="Rectangle">
                                <Setter Property="Width" Value="1" />
                                <Setter Property="Height" Value="18" />
                                <Setter Property="Margin" Value="5,0" />
                                <Setter Property="VerticalAlignment" Value="Center" />
                                <Setter Property="Fill" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
                            </Style>
                        </ResourceDictionary>
                    </Grid.Resources>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Find &amp; replace (Ctrl+F) -->
                    <Border x:Name="FindBar" Grid.Row="0" Visibility="Collapsed" Margin="16,12,16,0"
                            CornerRadius="6" BorderThickness="1" Padding="6" HorizontalAlignment="Left"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBox x:Name="FindBox" Width="170" PlaceholderText="Find"
                                     KeyDown="FindBox_KeyDown" />
                            <Button Content="Find next" Click="FindNext_Click" />
                            <TextBox x:Name="ReplaceBox" Width="170" PlaceholderText="Replace with" />
                            <Button Content="Replace" Click="Replace_Click" />
                            <Button Content="All" Click="ReplaceAll_Click" ToolTipService.ToolTip="Replace all" />
                            <Button Content="✕" Click="CloseFind_Click" ToolTipService.ToolTip="Close (Esc)" />
                        </StackPanel>
                    </Border>

                    <!-- Formatting toolbar — docked flush to the page, aligned with the
                         sidebar action header. Drives the WebView2 editor via execCommand. -->
                    <Border x:Name="ToolbarBar" Grid.Row="1" Height="48" Padding="10,0" BorderThickness="0,0,0,1"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                        <StackPanel Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Smaller text" Click="FontSmaller_Click">
                                <TextBlock Text="A−" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Bigger text" Click="FontBigger_Click">
                                <TextBlock Text="A+" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Width="Auto" Height="32" Padding="8,0" CornerRadius="6"
                                    Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Paragraph styles">
                                <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                    <TextBlock Text="Styles" FontSize="14" VerticalAlignment="Center" />
                                    <FontIcon Glyph="&#xE70D;" FontSize="10" />
                                </StackPanel>
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Title" Click="StyleTitle_Click" />
                                        <MenuFlyoutItem Text="Heading" Click="StyleHeading_Click" />
                                        <MenuFlyoutItem Text="Body" Click="StyleBody_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Button Style="{StaticResource FmtButton}" Width="44" ToolTipService.ToolTip="Font">
                                <TextBlock Text="Aa" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Calibri" Tag="Calibri" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Segoe UI" Tag="Segoe UI" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Times New Roman" Tag="Times New Roman" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Georgia" Tag="Georgia" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Consolas" Tag="Consolas" Click="Font_Click" />
                                        <MenuFlyoutSeparator />
                                        <MenuFlyoutItem Text="Padauk (Myanmar)" Tag="Padauk" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Myanmar Text" Tag="Myanmar Text" Click="Font_Click" />
                                        <MenuFlyoutItem Text="Noto Sans Myanmar" Tag="Noto Sans Myanmar" Click="Font_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Bold (Ctrl+B)" Click="Bold_Click">
                                <FontIcon Glyph="&#xE8DD;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Italic (Ctrl+I)" Click="Italic_Click">
                                <FontIcon Glyph="&#xE8DB;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Underline (Ctrl+U)" Click="Underline_Click">
                                <FontIcon Glyph="&#xE8DC;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Strikethrough" Click="Strike_Click">
                                <FontIcon Glyph="&#xEDE0;" FontSize="15" />
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Bullet list" Click="Bullets_Click">
                                <FontIcon Glyph="&#xE8FD;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Numbered list" Click="Numbered_Click">
                                <TextBlock Text="1." FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Checklist" Click="Checklist_Click">
                                <FontIcon Glyph="&#xE73A;" FontSize="15" />
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Highlight" Click="Highlight_Click">
                                <FontIcon Glyph="&#xE891;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Text color">
                                <FontIcon Glyph="&#xE8D3;" FontSize="15" />
                                <Button.Flyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Default" Click="ColorDefault_Click" />
                                        <MenuFlyoutItem Text="Red" Click="ColorRed_Click" />
                                        <MenuFlyoutItem Text="Green" Click="ColorGreen_Click" />
                                        <MenuFlyoutItem Text="Blue" Click="ColorBlue_Click" />
                                        <MenuFlyoutItem Text="Orange" Click="ColorOrange_Click" />
                                    </MenuFlyout>
                                </Button.Flyout>
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <Button x:Name="ReadAloudButton" Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Read aloud" Click="ReadAloud_Click">
                                <FontIcon x:Name="ReadAloudIcon" Glyph="&#xE767;" FontSize="15" />
                            </Button>
                            <Button x:Name="RecordButton" Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Record audio" Click="RecordAudio_Click">
                                <FontIcon x:Name="RecordIcon" Glyph="&#xE720;" FontSize="15" />
                            </Button>
                            <Rectangle Style="{StaticResource FmtSeparator}" />
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Linked references (backlinks)" Click="LinksButton_Click">
                                <FontIcon Glyph="&#xE71B;" FontSize="15" />
                            </Button>
                            <Button Style="{StaticResource FmtButton}" ToolTipService.ToolTip="Focus mode (F11)" Click="FocusMode_Click">
                                <FontIcon Glyph="&#xE740;" FontSize="15" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- The paper (inset from the flush toolbar and window edges).
                         Translation + ThemeShadow lift it off the backdrop so it floats. -->
                    <Border x:Name="PaperBorder" Grid.Row="2" CornerRadius="8" BorderThickness="1"
                            Margin="16,12,16,18" Translation="0,0,28"
                            Background="{ThemeResource PaperBrush}"
                            BorderBrush="{ThemeResource PaperStrokeBrush}">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- OneNote title block (wider side margins) -->
                            <StackPanel Grid.Row="0" Padding="72,28,72,0">
                                <TextBox x:Name="TitleBox" PlaceholderText="Page title"
                                         FontSize="30" FontWeight="Light" FontFamily="Calibri Light"
                                         Padding="0" Margin="0"
                                         TextChanged="TitleBox_TextChanged" />
                                <TextBlock x:Name="DateLine" FontSize="12" Opacity="0.55" Margin="1,8,0,0" />
                                <TextBlock x:Name="EditedLine" FontSize="12" Opacity="0.55" Margin="1,1,0,0" />
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <ItemsControl x:Name="NoteTagsList">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Spacing="6" />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <Button Padding="8,2" Background="Transparent">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <FontIcon Glyph="&#xE8EC;" FontSize="12" />
                                            <TextBlock Text="Tag" FontSize="12" />
                                        </StackPanel>
                                        <Button.Flyout>
                                            <Flyout>
                                                <StackPanel Width="220" Spacing="8">
                                                    <TextBlock Text="Add a tag" FontWeight="SemiBold" />
                                                    <AutoSuggestBox x:Name="AddTagBox" PlaceholderText="tag name"
                                                                    QueryIcon="Add"
                                                                    TextChanged="AddTagBox_TextChanged"
                                                                    QuerySubmitted="AddTagBox_QuerySubmitted" />
                                                    <Button Content="Add tag" Click="AddTag_Click" HorizontalAlignment="Right" />
                                                </StackPanel>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                                <Rectangle Height="1" Fill="{ThemeResource PaperRuleBrush}"
                                           HorizontalAlignment="Stretch" Margin="0,14,0,0" />
                            </StackPanel>

                            <!-- Body: a stack of plain-text + image blocks (true inline images).
                                 The hidden RichEditBox stays only so the legacy formatting code
                                 still compiles; the block editor below is what's used. -->
                            <Grid Grid.Row="1">
                                <Canvas x:Name="PaperCanvas" IsHitTestVisible="False"
                                        SizeChanged="PaperCanvas_SizeChanged" />
                                <RichEditBox x:Name="Editor" Visibility="Collapsed" FontFamily="Calibri"
                                             Background="Transparent" PlaceholderText="Start typing…"
                                             Padding="72,14,72,40"
                                             TextChanged="Editor_TextChanged" Tapped="Editor_Tapped"
                                             Paste="Editor_Paste" DoubleTapped="Editor_DoubleTapped" />
                                <!-- The real editor: a contenteditable HTML document. This is the
                                     only host that gives one continuous document with full-res,
                                     clickable, truly-inline images. -->
                                <WebView2 x:Name="NoteWeb" DefaultBackgroundColor="Transparent" />
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Screenshot thread: vertical image cards with timestamp -->
                <Grid x:Name="ThreadPane" Visibility="Collapsed" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,8" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ThreadTitleBox" Grid.Column="0" FontSize="20" FontWeight="SemiBold"
                                 BorderThickness="0" PlaceholderText="Thread title"
                                 TextChanged="TitleBox_TextChanged" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Click="ThreadExportAll_Click" VerticalAlignment="Center"
                                ToolTipService.ToolTip="Export every image in this thread to a folder">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE896;" FontSize="14" />
                                <TextBlock Text="Export all" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <ListView x:Name="ThreadCards" Grid.Row="1" SelectionMode="None"
                              Background="Transparent" Padding="0"
                              CanReorderItems="True" AllowDrop="True" CanDragItems="True"
                              DragItemsCompleted="ThreadCards_DragItemsCompleted">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0" />
                                <Setter Property="MinHeight" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,12" CornerRadius="8" Padding="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding Timestamp}" Opacity="0.6" FontSize="12" />
                                            <FontIcon Grid.Column="1" Glyph="&#xE76F;" FontSize="12" Opacity="0.4"
                                                      ToolTipService.ToolTip="Drag the card to reorder" />
                                        </Grid>
                                        <Image Source="{Binding Bitmap}" Stretch="Uniform"
                                               MaxHeight="480" HorizontalAlignment="Left"
                                               Tapped="ThreadImage_Tapped"
                                               ToolTipService.ToolTip="Click to view at 100%">
                                            <Image.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="View at 100%" Click="ThreadImageView_Click" />
                                                    <MenuFlyoutItem Text="Copy image" Click="ThreadImageCopy_Click" />
                                                    <MenuFlyoutItem Text="Export image…" Click="ThreadImageExport_Click" />
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Delete image" Click="ThreadImageDelete_Click" />
                                                </MenuFlyout>
                                            </Image.ContextFlyout>
                                        </Image>
                                        <TextBlock Text="{Binding Caption}" Opacity="0.8"
                                                   Margin="0,6,0,0" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <InfoBar x:Name="PasteHint" Grid.Row="2" IsOpen="True" IsClosable="False"
                             Severity="Informational" Margin="0,8,0,0"
                             Message="Press Ctrl+V to paste a screenshot into this thread." />
                </Grid>

                <!-- Search results -->
                <Grid x:Name="SearchResultsPane" Visibility="Collapsed" Padding="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SearchResultsHeader" Grid.Row="0" FontSize="13" Opacity="0.6" Margin="2,0,0,8" />
                    <ListView x:Name="SearchResultsList" Grid.Row="1" SelectionMode="Single"
                              IsItemClickEnabled="True" ItemClick="SearchResult_Click"
                              KeyDown="SearchResultsList_KeyDown">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="10,2" />
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>

                <!-- Empty state -->
                <TextBlock x:Name="EmptyState" Text="Select or create a note."
                           Opacity="0.6" HorizontalAlignment="Center"
                           VerticalAlignment="Center" />

                <!-- Floating exit affordance, shown only in focus mode -->
                <Button x:Name="FocusExitButton" Visibility="Collapsed" Click="FocusMode_Click"
                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,18,0"
                        CornerRadius="6" ToolTipService.ToolTip="Exit focus mode (Esc)"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE73F;" FontSize="13" />
                        <TextBlock Text="Exit focus" FontSize="13" />
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</Window>
