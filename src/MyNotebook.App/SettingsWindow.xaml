<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="MyNotebook.App.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Grid>
        <ScrollViewer Padding="22" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="6" MaxWidth="560" HorizontalAlignment="Left">

                <TextBlock Text="Appearance" FontWeight="SemiBold" Opacity="0.8" Margin="0,0,0,4" />
                <Grid ColumnSpacing="12" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Theme" VerticalAlignment="Center" />
                    <ComboBox x:Name="ThemeCombo" Grid.Column="1" MinWidth="160"
                              SelectionChanged="ThemeCombo_SelectionChanged">
                        <ComboBoxItem Content="Follow Windows" Tag="System" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>
                </Grid>
                <Grid ColumnSpacing="12" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Window background" VerticalAlignment="Center" />
                    <ComboBox x:Name="BackdropCombo" Grid.Column="1" MinWidth="160"
                              SelectionChanged="BackdropCombo_SelectionChanged">
                        <ComboBoxItem Content="Mica" Tag="Mica" />
                        <ComboBoxItem Content="Acrylic" Tag="Acrylic" />
                        <ComboBoxItem Content="Solid" Tag="Solid" />
                    </ComboBox>
                </Grid>
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Editor font size" VerticalAlignment="Center" />
                    <Slider x:Name="FontSizeSlider" Grid.Column="1" Minimum="11" Maximum="24"
                            Width="160" ValueChanged="FontSizeSlider_ValueChanged" />
                </Grid>

                <TextBlock Text="Color theme" Margin="0,8,0,2" />
                <TextBlock Text="Sets the accent and a matching page color together."
                           Opacity="0.6" FontSize="12" Margin="0,0,0,6" />
                <ItemsControl x:Name="AccentThemeList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
                <Grid ColumnSpacing="12" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Color intensity" VerticalAlignment="Center" />
                    <Slider x:Name="IntensitySlider" Grid.Column="1" Width="160"
                            Minimum="0" Maximum="200" StepFrequency="10"
                            ValueChanged="IntensitySlider_ValueChanged" />
                </Grid>

                <TextBlock Text="Note paper" FontWeight="SemiBold" Opacity="0.8" Margin="0,16,0,4" />
                <ToggleSwitch x:Name="PaperLinesToggle" Header="Faint rule lines on the page"
                              Toggled="PaperLinesToggle_Toggled" />
                <Grid ColumnSpacing="12" Margin="0,4,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Paper type" VerticalAlignment="Center" />
                    <ComboBox x:Name="PaperTypeCombo" Grid.Column="1" MinWidth="160"
                              SelectionChanged="PaperTypeCombo_SelectionChanged">
                        <ComboBoxItem Content="Ruled" Tag="Ruled" />
                        <ComboBoxItem Content="Grid" Tag="Grid" />
                        <ComboBoxItem Content="Dotted" Tag="Dotted" />
                        <ComboBoxItem Content="Notebook (ruled + margin)" Tag="Notebook" />
                    </ComboBox>
                </Grid>
                <TextBlock Text="Page color" Margin="0,4,0,2" />
                <ItemsControl x:Name="PageColorList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <TextBlock Text="Data &amp; storage" FontWeight="SemiBold" Opacity="0.8" Margin="0,16,0,4" />
                <TextBlock x:Name="StatsText" Opacity="0.8" TextWrapping="Wrap" />
                <TextBlock x:Name="DataPathText" Opacity="0.6" FontSize="12" TextWrapping="Wrap"
                           IsTextSelectionEnabled="True" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button x:Name="OpenDataFolderButton" Content="Open data folder" Click="OpenDataFolder_Click" />
                    <Button x:Name="BackupButton" Content="Back up to .zip" Click="Backup_Click" />
                    <Button x:Name="ExportAllButton" Content="Export all (Markdown)" Click="ExportAll_Click" />
                    <Button x:Name="EmptyTrashButton" Content="Empty trash" Click="EmptyTrash_Click" />
                </StackPanel>

                <TextBlock Text="Search &amp; OCR" FontWeight="SemiBold" Opacity="0.8" Margin="0,16,0,4" />
                <TextBlock x:Name="OcrStatusText" Opacity="0.8" TextWrapping="Wrap" />
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                    <Button x:Name="RerunOcrButton" Content="Re-run OCR on all images" Click="RerunOcr_Click" />
                    <Button x:Name="RebuildIndexButton" Content="Rebuild search index" Click="RebuildIndex_Click" />
                </StackPanel>
                <ProgressBar x:Name="MaintProgress" Visibility="Collapsed" Margin="0,4,0,0" />

                <TextBlock Text="Behavior" FontWeight="SemiBold" Opacity="0.8" Margin="0,16,0,4" />
                <ToggleSwitch x:Name="ConfirmDeleteToggle" Header="Confirm before deleting a note"
                              Toggled="ConfirmDeleteToggle_Toggled" />
                <ToggleSwitch x:Name="SpellCheckToggle" Header="Spell check in the editor"
                              Toggled="SpellCheckToggle_Toggled" />
                <ToggleSwitch x:Name="CloseToTrayToggle" Header="Close button hides to the system tray"
                              Toggled="CloseToTrayToggle_Toggled" />
                <ToggleSwitch x:Name="QuickNoteToggle" Header="Quick Note global hotkey (Win+Alt+N)"
                              Toggled="QuickNoteToggle_Toggled" />
                <ToggleSwitch x:Name="PasteSourceToggle" Header="Keep source link when pasting from the web"
                              Toggled="PasteSourceToggle_Toggled" />

                <TextBlock Text="About" FontWeight="SemiBold" Opacity="0.8" Margin="0,16,0,4" />
                <TextBlock x:Name="AboutText" Opacity="0.7" TextWrapping="Wrap" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
